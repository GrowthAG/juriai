# JuriAI — exemplo de variáveis de ambiente (staging/production).
# Copie para um secret store (Secret Manager). NUNCA commitar valores reais.
# Arquivo .env* permanece no .gitignore; este .env.example é a exceção documentada.

# --- Runtime ---
NODE_ENV=production
# Cloud Run injeta PORT; localmente:
# PORT=8080

# OBRIGATÓRIO em qualquer ambiente não-local de dev:
JURIAI_ALLOW_DEV_BYPASS=false

# --- Banco (Cloud SQL) ---
# Use connector/socket do Cloud Run ou host privado — não 127.0.0.1 de laptop.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/juriai?schema=public
# Exemplo via socket do Cloud Run (escape a senha para uso em URL):
# DATABASE_URL=postgresql://USER:PASSWORD@localhost/juriai?host=/cloudsql/PROJECT:REGION:INSTANCE&schema=public

# --- Sessão ---
# String longa e aleatória (mínimo exigido pelo código em lib/session-token.ts).
JURIAI_SESSION_SECRET=change-me-to-a-long-random-string

# --- OAuth Google (NextAuth) ---
# Segredo usado pelo Auth.js durante o handshake OAuth. Use um valor distinto
# de JURIAI_SESSION_SECRET.
AUTH_SECRET=change-me-to-another-long-random-string
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# URL canônica do ambiente (também faz o Auth.js confiar no host do Cloud Run):
AUTH_URL=https://staging.example.com
JURIAI_APP_URL=https://app.juriai.adv.br

# --- Google Cloud / Vertex (Gemini) ---
# Preferir Workload Identity / service account do Cloud Run (ADC), sem JSON no repo.
GOOGLE_CLOUD_PROJECT=juriai-app
JURIAI_TASKS_LOCATION=us-central1
JURIAI_INGESTION_QUEUE=juriai-ingestion
JURIAI_TASKS_BASE_URL=https://seu-servico.run.app
JURIAI_TASKS_SERVICE_ACCOUNT=service-account@projeto.iam.gserviceaccount.com
JURIAI_TASKS_AUTH_TOKEN=gere-um-segredo-forte
# Opcional se o workspace não tiver llmProjectId:
# ANTHROPIC_VERTEX_PROJECT_ID=juriai-app
# CLOUD_ML_REGION=us-central1
# GOOGLE_CLOUD_LOCATION=us-central1

# Defaults LLM (opcional; workspace Almeida já pode ter override no banco):
# JURIAI_LLM_PROVIDER=google-vertex-gemini
# JURIAI_LLM_MODEL=gemini-2.5-pro

# NÃO usar em staging/prod se a política for só Google Startups:
# ANTHROPIC_API_KEY=

# --- Uploads (filesystem) ---
# Monte um bucket Cloud Storage neste caminho com uid=1001 e gid=1001.
JURIAI_UPLOAD_DIR=/var/juriai/uploads
# Em produção, configure ambos para gravar primeiro no bucket não verificado.
JURIAI_UNSCANNED_UPLOAD_DIR=/var/juriai/unscanned
JURIAI_QUARANTINE_UPLOAD_DIR=/var/juriai/quarantine

# --- Integrações opcionais ---
# DATAJUD_API_KEY=
# DATAJUD_BASE_URL=https://api-publica.datajud.cnj.jus.br
