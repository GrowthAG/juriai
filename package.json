{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:3002": "next dev -p 3002",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app components lib e2e --no-error-on-unmatched-pattern",
    "proxy": "./cloud-sql-proxy juriai-app:us-central1:juriai-db --port 5432",
    "db:check": "node scripts/check-db.mjs",
    "db:init": "node scripts/init-db.mjs",
    "db:bootstrap-admin": "node scripts/bootstrap-admin.mjs",
    "db:patch": "node scripts/apply-sql.mjs",
    "db:apply": "node scripts/apply-sql.mjs",
    "claude:login": "./scripts/claude-personal login",
    "claude:status": "./scripts/claude-personal status",
    "claude:start": "./scripts/claude-personal start",
    "team:bootstrap": "node scripts/team-registry.mjs bootstrap",
    "team:rotate": "node scripts/team-registry.mjs rotate",
    "team:bus": "npm --prefix tools/agent-bus start",
    "team:up": "node scripts/team-bus.mjs start",
    "team:down": "node scripts/team-bus.mjs stop",
    "team:status": "node scripts/team-bus.mjs status",
    "team:doctor": "node scripts/team-bus.mjs doctor",
    "team:pilot": "node tools/agent-bus/src/pilot.mjs",
    "team:terminal": "node scripts/team-terminal.mjs",
