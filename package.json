    "google-auth-library": "^10.9.0",
    "motion": "^12.42.2",
    "next": "16.2.9",
    "next-auth": "5.0.0-beta.31",
    "pdf-lib": "^1.17.1",
    "pg": "^8.22.0",
    "prisma": "^5.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "eslint": "^9",
