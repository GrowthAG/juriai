# O padrão já limita o serviço à máquina local.
JURIAI_AGENT_BUS_HOST=127.0.0.1
JURIAI_AGENT_BUS_PORT=8766
JURIAI_AGENT_BUS_DB=./data/agent-bus.sqlite

# Opcional. Se definido, configure o mesmo bearer token em todos os clientes MCP.
# JURIAI_AGENT_BUS_TOKEN=troque-por-um-segredo-longo

# O wake do Mosaic é opt-in para não digitar em terminais sem autorização.
JURIAI_MOSAIC_WAKE=0
# JURIAI_MOSAIC_BIN=/Applications/Mosaic.app/Contents/Resources/bin/mosaic
